{
  "layer": "top",
  "position": "top",
  "height": 38,
  "spacing": 6,
  "margin-top": 0,
  "margin-bottom": 0,
  
  "modules-left": ["hyprland/workspaces","mpris"],
  "modules-center": [
    "custom/wifi",
    "bluetooth",
    "power-profiles-daemon",
    "battery",
    "clock",
    "custom/power"
  ],
  "modules-right": [
    "custom/notifications",
    "hyprland/language",
    "custom/volume"
  ],

  "custom/power": {
    "format": "βèΜ",
    "on-click": "wlogout",
    "tooltip": false
  },
  
  "mpris": {
      "format": "{player_icon} {title}",
      "format-paused": "{status_icon} {title}",
      "player-icons": {
          "default":  "σΑùö",
          "spotify":  "",
          "firefox":  "",
          "chromium": "",
          "mpd":      "σΑéÜ"
      },
      "status-icons": {
          "paused": "σΑèΛ"
      },
      // "on-click": "eww open music_pop || eww close music_pop"
      "on-click": "~/.config/eww/toggle-music.sh",
      "on-click-right": "playerctl play-pause",
      "on-scroll-up": "playerctl next",
      "on-scroll-down": "playerctl previous",
      "max-length": 40,
      "interval": 1,
      "dynamic-len": 35,
      "tooltip": true
  },



  "hyprland/language": {
    "format": "σΑ¨¨ {}", // Icona tastiera Nerd Font
    "format-en": "US",
    "format-it": "IT",
    "min-length": 5,
    "tooltip": true
},

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "persistent-workspaces": {
      "*": 5
    }
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Profilo: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "performance": "οÉß",
      "balanced": "οâé",
      "power-saver": "ο¹§" // Icona foglia per il risparmio
    }
},

  "custom/wifi": {
    "format": "{}",
    "interval": 5,
    "exec": "~/.config/waybar/scripts/wifi.sh",
    "on-click": "kitty -e impala",
    "tooltip": true,
    "return-type": "json"
  },

  "bluetooth": {
    "format": "οä™ {}",
    "interval": 5,
    "exec": "~/.config/waybar/scripts/bluetooth.sh",
    "on-click": "kitty -e bluetui",
    "tooltip": true,
    "return-type": "json"
  },

  "battery": {
    "bat": "BAT1",
    "adapter": "ACAD",
    "full-at": 98,
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "σΑ²³ {capacity}%",
    "format-plugged": "σ±ê΄ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
    "interval": 5
  },

  "clock": {
    "format": "σΑÖê {:%H:%M}",
    "format-alt": "σΑÉ≠ {:%d/%m/%Y}",
    "tooltip-format": "<big>{:%A %d %B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    "interval": 60,
    "on-click": "gnome-calendar"
  },

  "custom/volume": {
    "format": "{}",
    "interval": 1,
    "exec": "~/.config/waybar/scripts/volume.sh",
    "return-type": "json",
    "signal": 1, // Aggiungi questo
    "on-click": "pavucontrol",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ && pkill -RTMIN+1 waybar",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- && pkill -RTMIN+1 waybar"
},

  "custom/notifications": {
    "format": "σΑ²ö {}",
    "interval": 2,
    "exec": "~/.config/waybar/scripts/notifications.sh",
    "on-click": "swaync-client -t",
    "tooltip": true,
    "return-type": "json"
  },

  "custom/calendar": {
    "format": "σΑΗ½ {}",
    "interval": 60,
    "exec": "date '+%d/%m'",
    "on-click": "gnome-calendar",
    "tooltip": true,
    "tooltip-format": "date '+%A %d %B %Y'"
  }
}
